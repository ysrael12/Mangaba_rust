# ========================================
# MANGABA AI â€” Environment Configuration
# ========================================
# Copy to .env and fill in your credentials
#
#   cp .env.example .env

# ==========================================
# LLM PROVIDER (required for real inference)
# ==========================================
# Supported: google, openai, anthropic, huggingface
# Aliases: geminiâ†’google, gpt/chatgptâ†’openai, claudeâ†’anthropic, hfâ†’huggingface
LLM_PROVIDER=google

# --- Google / Gemini ---
GOOGLE_API_KEY=
GEMINI_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=

# --- HuggingFace ---
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=
HF_TOKEN=

# Fallback (used when no provider-specific key is set)
API_KEY=

# ==========================================
# MODEL CONFIG (optional)
# ==========================================
MODEL_NAME=gemini-2.5-flash
MODEL_TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=1024

# Override the API base URL (rarely needed)
# BASE_URL=https://api.openai.com/v1

# ==========================================
# LOGGING (optional)
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# SERPER (optional â€” for SerperSearchTool)
# ==========================================
# Get your key at https://serper.dev
SERPER_API_KEY=
